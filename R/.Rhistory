data(mpg, package = "ggplot2")
summary_ct(mpg, "hwy")
summary_ct(mpg, "hwy", group = "class")
summary_ct <-  function(data, response, group=NA, na.rm= TRUE){
# -------Lambda Summaries------
# 5 number Summary
# Variance (lambda)
# Mean To Variance Ratio(lambda)
# Zero Count Proportion(lambda)
if(is.na(group)){
# using [[response]] instead of $
summary_data <- tibble(
Min. = min(data[[response]],na.rm = na.rm),
"1st Qu." = quantile(data[[response]], prob = 0.25,na.rm = na.rm),
Median = median(data[[response]],na.rm = na.rm),
Mean = mean(data[[response]],na.rm = na.rm),
"3rd Qu." =  unname(quantile(data[[response]], prob = 0.75,na.rm = na.rm)),
Max. = max(data[[response]]),
zero_prop = mean(data[[response]] == 0,na.rm = na.rm),
variance = var(data[[response]],na.rm = na.rm),
Var_to_Mean = mean(data[[response]]) / var(data[[response]],na.rm = na.rm)
)
return(summary_data)
}
else{
summary_data <- data %>% group_by(data[[group]]) %>%
summarise(  Min. = min(data[[response]],na.rm = na.rm),
"1st Qu." = quantile(data[[response]], prob = 0.25,na.rm = na.rm),
Median = median(data[[response]],na.rm = na.rm),
Mean = mean(data[[response]],na.rm = na.rm),
"3rd Qu." = quantile(data[[response]], prob = 0.75,na.rm = na.rm),
Max. = max(data[[response]]),
zero_prop = mean(data[[response]] == 0,na.rm = na.rm),
variance = var(data[[response]],na.rm = na.rm),
Var_to_Mean = mean(data[[response]]) / var(data[[response]],na.rm = na.rm) ) %>%
ungroup() %>% rename( "Group" = "data[[group]]" )
return(summary_data)
}
}
# Some Testing out the function
data(mpg, package = "ggplot2")
summary_ct(mpg, "hwy")
summary_ct(mpg, "hwy", group = "class")
