filter(!is.na(Value))
p1  <- ggplot(performance_long_clean, aes(x = Metric, y = Value, fill = Model)) +
geom_col(position = "dodge") +
ylim(0, 1) +
labs(title = "Merge True Examples Performance Metrics",
x = "Metric",
y = "Value") +
scale_fill_brewer(palette = "Set3") +  # nicer palette
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
